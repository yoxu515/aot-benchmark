# =========================
# Normalize line endings
# =========================
* text=auto

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf

# =========================
# Binary files (no diff)
# =========================
*.pt binary
*.pth binary
*.ckpt binary
*.npy binary
*.npz binary

# =========================
# CSV / JSON (treat as text)
# =========================
*.csv text
*.json text

# =========================
# Notebooks
# =========================
*.ipynb text

# =========================
# Images
# =========================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary